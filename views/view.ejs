<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Data</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #eef2f3, #dbeafe);
            padding: 40px 20px;
        }

        .container {
            max-width: 1100px;
            margin: auto;
        }

        h1 {
            text-align: center;
            font-size: 32px;
            color: #111827;
            margin-bottom: 30px;
        }

        .table-wrapper {
            background: #ffffff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            border: 1px solid #e5e7eb;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #6594f3a0;
        }

        th {
            padding: 16px;
            text-align: left;
            font-size: 13px;
            color: #374151;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        td {
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            color: #374151;
            font-size: 14px;
        }

        .badge {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: #e0f2fe;
            color: #0369a1;
            text-transform: capitalize;
        }

        .actions {
            display: flex;
            gap: 8px;
        }

        .view {
            background: #e0f2fe;
            color: #0369a1;
        }

        .edit {
            background: #fef3c7;
            color: #92400e;
        }

        .delete {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn {
            border: none;
            padding: 7px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .view:hover {
            background: #bae6fd;
        }

        .edit:hover {
            background: #fde68a;
        }

        .delete:hover {
            background: #fecaca;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .header-section h1 {
            margin: 0;
        }

        .page-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            background: #eff6ff;
            color: #2563eb;
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid #bfdbfe;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .page-link:hover {
            background: #dbeafe;
        }

        @media (max-width: 768px) {
            .table-wrapper {
                overflow-x: auto;
            }

            table {
                min-width: 700px;
            }
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="header-section">
            <h1>Inventory Data</h1>

            <a href="/" class="page-link">
                + Add Inventory
            </a>
        </div>

        <div class="table-wrapper">

            <table>

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (products.length===0) { %>
                        <tr>
                            <td colspan="7" class="no-data" align="center">
                                No products available
                            </td>
                        </tr>
                        <% } else { %>

                            <% products.forEach((prd, index)=> { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td><strong>
                                            <%= prd.productName %>
                                        </strong>
                                    </td>
                                    <td>
                                        <span class="badge">
                                            <%= prd.category %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= prd.quantity %>
                                    </td>
                                    <td>
                                        ₹<%= prd.price %>
                                    </td>
                                    <td>
                                        <div class="actions">
                                            <a href="/view-inventory/<%= prd.id %>" class="btn view">View</a>
                                            <a href="/edit-inventory/<%= prd.id %>" class="btn edit">Edit</a>
                                            <a href="/delete-inventory/<%= prd.id %>" class="btn delete">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                </tbody>

            </table>

        </div>

    </div>

</body>

</html>